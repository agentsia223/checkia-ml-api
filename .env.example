# Copy to .env and fill in. .env is gitignored.

# Configured providers/models. Swap by editing these.
MT_MODEL=google-translate-v2
ASR_MODEL=sudoping01/bambara-asr-v2

# Inference device for local models (ASR): cpu | cuda | mps
DEVICE=cpu

# Hugging Face token, required for gated models (ASR).
HF_TOKEN=

# Google Cloud Translation API key (Basic / v2), required for translation.
GOOGLE_TRANSLATE_API_KEY=
