# Copy to .env and fill in. .env is gitignored.

# Configured models (Hugging Face id or local path). Swap by editing these.
MT_MODEL=facebook/nllb-200-distilled-600M
ASR_MODEL=sudoping01/bambara-asr-v2

# Inference device: cpu | cuda | mps
DEVICE=cpu

# Hugging Face token, required for gated models.
HF_TOKEN=
